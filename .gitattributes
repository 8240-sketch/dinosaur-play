* text=auto eol=lf

.gitattributes text eol=lf

# Ensure shell scripts always use LF (required for bash on all platforms)
*.sh text eol=lf

# GDScript and Ink source files use LF
*.gd text eol=lf
*.ink text eol=lf

# 文本配置文件使用 LF，保持跨平台一致性
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.cfg text eol=lf

# Windows 批处理脚本保留 CRLF
*.bat text eol=crlf

# Binary assets: never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.ogg binary
*.wav binary
*.mp3 binary
*.import binary
*.tscn text eol=lf
*.tres text eol=lf
